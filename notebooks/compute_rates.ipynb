   "source": [
    "# Compute genome-wide rates for each host category (all, human, avian)¥n",
    "genome_wide_evo_opp_threshold = 1.0¥n",
    "genome_wide_rates = (¥n",
    "    counts_df[counts_df['evo_opp'] > genome_wide_evo_opp_threshold]¥n",
    "    .groupby(['mut_type', 'mut_class', 'host'])[['actual_count', 'evo_opp']].sum()¥n",
    "    .assign(rate = lambda x: x['actual_count'] / x['evo_opp'])¥n",
    "    .reset_index()¥n",
    ")¥n",
    "¥n",
    "# Compute rates relative to synonymous mutations of a given mutation type¥n",
    "syn_genome_wide_rates = (¥n",
    "    genome_wide_rates[genome_wide_rates['mut_class'] == 'synonymous'].copy()¥n",
    "    .rename(columns={'rate':'syn_rate'})¥n",
    ")¥n",
    "genome_wide_rates = (¥n",
    "    genome_wide_rates¥n",
    "    .merge(syn_genome_wide_rates[['mut_type', 'host', 'syn_rate']])¥n",
    "    .assign(rel_rate = lambda x: x['rate'] / x['syn_rate'])¥n",
    "    .assign(mut_type_arrow = lambda x: x['mut_type'].str[0] + '$¥¥¥¥to$' + x['mut_type'].str[1])¥n",
    "    .sort_values(['mut_type', 'mut_class', 'host'])¥n",
    ")¥n",
    "¥n",
    "# Write rates to an output file¥n",
    "genome_wide_rates.to_csv('../results/genome_wide_rates.csv', index=False)¥n",
    "genome_wide_rates.head()"
   ]
