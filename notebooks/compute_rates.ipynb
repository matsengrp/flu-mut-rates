   "source": [
    "# Add a column that bins rows by evolutionary opportunity, defining bin edges in log space¥n",
    "bin_mins = np.logspace(0, 2.5, num=15)¥n",
    "labels = list(map(float, bin_mins[:-1]))¥n",
    "counts_df['evo_opp_bin'] = pd.cut(counts_df['evo_opp'], bins=bin_mins, include_lowest=True, labels=labels)¥n",
    "counts_df['evo_opp_bin'] = counts_df['evo_opp_bin'].astype(float)¥n",
    "¥n",
    "# Compute summary stats of rates in bins of evo opp¥n",
    "metric = 'actual_count'¥n",
    "data = (¥n",
