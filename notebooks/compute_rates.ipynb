   "source": [
    "# Compute rates¥n",
    "rates_df = (¥n",
    "    counts_df¥n",
    "    # remove data at the first and last sites in each segment, since they doesn't have a full 3mer motif¥n",
    "    .assign(max_site = lambda x: x.groupby(['subtype', 'segment'])['site'].transform('max'))¥n",
    "    .query('1 < site < max_site')¥n",
    "    # only analyze mutations with sufficient evolutionary opportunities¥n",
    "    .merge(evo_opp_thresholds[['mut_type', 'evo_opp_threshold']])¥n",
    "    .query('evo_opp >= evo_opp_threshold')¥n",
    "    # clip rates at lower limit of detection¥n",
    "    .assign(unclipped_rate = lambda x: x['rate'])¥n",
    "    .assign(min_rate = lambda x: 1 / x['evo_opp_threshold'])¥n",
    "    .assign(rate = lambda x: x[['min_rate', 'rate']].max(axis=1))¥n",
    ")¥n",
    "¥n",
    "# Save the rates to a file¥n",
    "rates_df.to_csv('../results/site_specific_mutation_rates.csv', index=False)¥n",
    "rates_df.head()"
   ]
