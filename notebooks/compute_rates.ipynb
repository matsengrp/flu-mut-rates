   "source": [
    "# Function for reading in data¥n",
    "def read_counts(f, segment, subtype, host):¥n",
    "    df = pd.read_csv(f, keep_default_na=False, low_memory=False)¥n",
    "    df = df.replace('', np.nan)¥n",
    "    df['subtype'] = subtype¥n",
    "    df['segment'] = segment¥n",
    "    df['segment_subtype'] = df['segment'] + '_' + df['subtype']¥n",
    "    df['segment_length'] = df['site'].max() - df['site'].min()¥n",
    "    df['host'] = host¥n",
    "    return df¥n",
    "¥n",
    "# Cycle over segments and hosts and read in data¥n",
    "segments = ['PB2', 'PB1', 'PA', 'HA', 'NP', 'NA', 'NS', 'MP']¥n",
    "hosts = ['avian', 'human']¥n",
    "dfs = []¥n",
    "for segment in segments:¥n",
    "    subtype_dirs = [d for d in glob.glob(f'../results/{segment}/*') if os.path.isdir(d)]¥n",
    "    for subtype_dir in subtype_dirs:¥n",
    "¥n",
    "        # Read in counts from the tree with all sequences¥n",
    "        subtype = os.path.basename(subtype_dir)¥n",
    "        f = os.path.join(subtype_dir, 'mutation_counts.csv')¥n",
    "        df = read_counts(f, segment, subtype, 'all')¥n",
    "        dfs.append(df)¥n",
    "¥n",
    "        # Read in counts from host-specific trees¥n",
    "        for host in hosts:¥n",
    "            host_dir = os.path.join(subtype_dir, host)¥n",
    "            f = os.path.join(host_dir, 'mutation_counts.csv')¥n",
    "            df = read_counts(f, segment, subtype, host)¥n",
    "            dfs.append(df)¥n",
    "¥n",
    "counts_df = (¥n",
    "    pd.concat(dfs)¥n",
    "    .rename(columns={'parent_motif':'motif'})¥n",
    ")¥n",
    "¥n",
    "# Compute evolutionary opportunities and rates¥n",
    "counts_df['evo_opp'] = counts_df['branch_length'] / counts_df['segment_length']¥n",
    "counts_df['rate'] = counts_df['actual_count'] / counts_df['evo_opp']¥n",
    "¥n",
    "# Remove rows with incomplete motifs (e.g. sites near the ends of the segment)¥n",
    "counts_df = counts_df[¥n",
    "    (counts_df['motif'].notnull()) &¥n",
    "    (counts_df['motif'].str.len() == 3)¥n",
    "]¥n",
    "¥n",
    "# Save counts data to a file¥n",
    "counts_df.sort_values('mut_type', inplace=True)¥n",
    "counts_df.to_csv('../results/counts.csv', index=False)¥n",
    "¥n",
    "counts_df.head()"
   ]
  },
