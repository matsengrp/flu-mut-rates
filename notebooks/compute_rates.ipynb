   "source": [
    "# Define bins¥n",
    "nbins = 10¥n",
    "evo_vals = counts_df['evo_opp']¥n",
    "evo_vals = evo_vals[evo_vals > 0]¥n",
    "bins = np.geomspace(evo_vals.min(), evo_vals.max(), nbins + 1)¥n",
    "¥n",
    "# Function for sorting by segment and subtype¥n",
    "def sort_segment_subtype(segment_subtype):¥n",
    "    segment = segment_subtype.split('_')[0]¥n",
    "    if segment == 'HA':¥n",
    "        return (0, segment_subtype)¥n",
    "    elif segment == 'NA':¥n",
    "        return (1, segment_subtype)¥n",
    "    else:¥n",
    "        return (2, segment_subtype)¥n",
    "¥n",
    "# Make one plot per host¥n",
    "for (host, host_data) in counts_df.groupby('host'):¥n",
    "    host_data.sort_values('segment_subtype', key=lambda x: x.apply(sort_segment_subtype), inplace=True)¥n",
    "    (fig, axs) = plt.subplots(ncols=8, nrows=2, figsize=[10,4], sharey=True)¥n",
    "    axs = axs.reshape(-1)¥n",
    "    for (i, segment_subtype) in enumerate(host_data['segment_subtype'].unique()):¥n",
    "        subtype_data = host_data[host_data['segment_subtype'] == segment_subtype]¥n",
    "        (segment, subtype) = segment_subtype.split('_')¥n",
    "        if len(subtype_data) == 0:¥n",
    "            continue¥n",
    "        sns.histplot(x='evo_opp', data=subtype_data, ax=axs[i], bins=bins)¥n",
    "        axs[i].set(¥n",
    "            xscale='log', yscale='log', title=f'{segment} ({subtype})',¥n",
    "            ylabel='', xlabel='',¥n",
    "            xlim=(evo_vals.min(), evo_vals.max()),¥n",
    "            xticks=[1e-2, 1e0, 1e2]¥n",
    "        )¥n",
    "        axs[i].grid()¥n",
    "¥n",
    "    # Add common y label¥n",
    "    fig.text(-0.01, 0.5, 'number of mutations', va='center', rotation='vertical')¥n",
    "    fig.text(0.42, -0.01, 'evolutionary opportunity', va='center', rotation='horizontal')¥n",
    "¥n",
    "    plt.suptitle(f'{host} hosts')¥n",
    "¥n",
    "    plt.tight_layout()¥n",
    "    sns.despine()¥n",
    "    plt.show()"
   ]
